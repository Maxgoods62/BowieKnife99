# Paths for tools/extract_vo.py — copy this file to `.env` (same folder) and set them for your machine.
# Use Windows-style paths (the script converts them to WSL /mnt mounts automatically).

# Your Cyberpunk 2077 install folder (contains archive\, r6\, engine\, ...)
CP2077_DIR=D:\Games\Cyberpunk 2077

# WolvenKit CLI executable — https://github.com/WolvenKit/WolvenKit (Console/CLI build)
WOLVENKIT_CLI=C:\Tools\WolvenKit\WolvenKit.CLI.exe

# vgmstream CLI executable — https://github.com/vgmstream/vgmstream/releases (vgmstream-win64.zip)
VGMSTREAM_CLI=C:\Tools\vgmstream\vgmstream-cli.exe

# Scratch folder for raw .wem extraction (any writable dir; created if missing)
VO_TMP=C:\Temp\bowie_vo_extract
